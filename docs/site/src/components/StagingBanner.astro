---
// Replaces Starlight's per-page <Banner /> slot so a site-wide notice
// renders on every page. The original per-page `banner` frontmatter
// field still takes precedence if present (we check Astro.locals for it).
const frontmatterBanner = Astro.locals.starlightRoute?.entry?.data?.banner;
---

{frontmatterBanner ? (
  <div class="sl-banner" set:html={frontmatterBanner.content} />
) : (
  <div class="sl-banner sl-banner-staging">
    <strong>Staging preview</strong> — this site reflects an in-progress branch and may change without notice.
  </div>
)}

<style>
  .sl-banner-staging {
    --__banner-bg: var(--sl-color-orange-low, #3d2a00);
    --__banner-text: var(--sl-color-orange-high, #ffbe6e);
    background: var(--__banner-bg);
    color: var(--__banner-text);
    padding: 0.5rem 1rem;
    text-align: center;
    font-size: 0.8125rem;
    border-bottom: 1px solid var(--sl-color-orange, #e09c3a);
  }
</style>
